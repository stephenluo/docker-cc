#!/usr/bin/env bash
# cc：宿主端 wrapper，docker compose 的薄封装。
# 详见 docs/implementation-plan.md §7.1

set -eo pipefail

# 关键：先保存用户调用 dcc 时的工作目录，再 cd 到 compose 目录
# 否则 docker-compose.yml 里的 ${PWD} 会被解析成 compose 目录，工作目录就挂错了
export HOST_PWD="$PWD"
COMPOSE_DIR="${DOCKER_CC_HOME:-$HOME/.docker-cc/repo}"

[ -d "$COMPOSE_DIR" ] || {
  echo "未找到 $COMPOSE_DIR。请先运行 install.sh，或设置 DOCKER_CC_HOME。"
  exit 1
}
cd "$COMPOSE_DIR"

# 仅提取 dcc 脚本需要的变量（不能 source 整个 .env：CLASH_SUB_URL 含 & ? 等
# shell 元字符时 source 会语法错；docker compose 读 .env 不走 shell 语法所以无碍）
if [ -f .env ]; then
  while IFS='=' read -r k v; do
    case "$k" in
      UI_PORT)  v="${v%\"}"; UI_PORT="${v#\"}" ;;
      DCC_REPO) v="${v%\"}"; DCC_REPO="${v#\"}" ;;
    esac
  done < .env
fi
# dcc upgrade 探测 latest 版本时使用；fork 用户可在 .env 里加 DCC_REPO=myfork/docker-cc 覆盖
DCC_REPO="${DCC_REPO:-stephenluo/docker-cc}"

# 读版本号（VERSION 文件由 install.sh 复制到 COMPOSE_DIR）
DCC_VERSION="$(cat VERSION 2>/dev/null || echo dev)"

# --version / -v：单独显示版本，不透传给 claude，不打 banner
if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
  echo "dcc v${DCC_VERSION}"
  exit 0
fi

# 其他所有调用：开始时打一行 banner（输出到 stderr 不污染 stdout）
echo "dcc v${DCC_VERSION}" >&2

case "${1:-}" in
  up)
    shift
    if [ -n "${1:-}" ]; then
      # 首次或想换订阅时：dcc up <url> 直接传订阅链接，自动写入 .env 并强制重拉
      # 用 grep -v + 追加替代 sed，避免 URL 含 | / & / \ 等特殊字符破坏 sed 模式
      # URL 加双引号写入：docker compose 解析 .env 时会去引号；防御 URL 含 & 等元字符
      url="$1"
      { grep -v '^CLASH_SUB_URL=' .env 2>/dev/null || true; echo "CLASH_SUB_URL=\"${url}\""; } > .env.tmp
      mv .env.tmp .env
      chmod 600 .env       # 订阅 URL 可能内嵌 token
      REFRESH_SUB=1 exec docker compose up -d mihomo
    else
      # 之后：dcc up 直接复用 .env 里的 URL
      if [ ! -f .env ] || ! grep -q '^CLASH_SUB_URL=.' .env; then
        echo "首次使用请指定订阅: dcc up <subscription-url>"
        exit 1
      fi
      exec docker compose up -d mihomo
    fi
    ;;
  down)   exec docker compose down ;;
  logs)   shift; exec docker compose logs "$@" mihomo ;;
  panel)
    url="http://127.0.0.1:${UI_PORT:-19090}/ui"
    if   command -v open      >/dev/null 2>&1; then exec open      "$url"
    elif command -v xdg-open  >/dev/null 2>&1; then exec xdg-open  "$url"
    else echo "请在浏览器打开：$url"; fi ;;
  shell)  exec docker compose run --rm cc bash ;;
  login)
          # 切到 OAuth 模式（清空 settings.json 的 env，避免 API key 抢占）
          dcc-use claude-account
          echo "进入 claude 交互界面后，输入 /login 完成 OAuth 流程（终端会显示 URL，"
          echo "用宿主浏览器打开授权，再把 token 复制粘贴回容器终端）。完成后 Ctrl+D 退出。"
          exec docker compose run --rm cc claude ;;
  logout)
          echo "进入 claude 交互界面后，输入 /logout 退出账号。"
          exec docker compose run --rm cc claude ;;
  refresh)
          REFRESH_SUB=1 exec docker compose up -d --force-recreate mihomo ;;
  probe)
          # 共享脚本（与 install.sh 同源）维护探测逻辑 + 镜像源列表
          exec "$COMPOSE_DIR/bin/_dcc-probe-ghproxy" "$COMPOSE_DIR/.env" ;;
  upgrade)
          # 升级：默认探测 GitHub Release latest 自动切到新版，--to=<v> 显式指定，
          # --keep 保持当前 pin（仅刷新镜像 layer），--build 本地构建。
          # ⚠ 不要用 dcc update —— claude code 装在镜像层，--rm 容器内 npm 更新会被丢弃。
          shift
          FORCE_BUILD=0
          TARGET_VER=""    # 空 = 探测 latest；keep = 保持当前；<x.y.z> = 指定版本
          while [ $# -gt 0 ]; do
            case "$1" in
              --build)  FORCE_BUILD=1; shift ;;
              --keep)   TARGET_VER="keep"; shift ;;
              --to=*)   TARGET_VER="${1#--to=}"; shift
                        [ -n "$TARGET_VER" ] || { echo "--to= 后需要版本号"; exit 1; } ;;
              --to)     shift
                        [ -n "${1:-}" ] || { echo "--to 后需要版本号"; exit 1; }
                        TARGET_VER="$1"; shift ;;
              claude|all|mihomo) break ;;
              *) echo "未知参数: $1"
                 echo "用法: dcc upgrade [--build|--keep|--to=<version>] [claude|mihomo|all]"
                 exit 1 ;;
            esac
          done
          case "${1:-claude}" in
            claude|all)
              if [ "$FORCE_BUILD" = "1" ]; then
                if ! docker compose build --no-cache --pull; then
                  echo ""
                  echo "build 失败。常见原因：GH_PROXY 镜像源临时挂掉。"
                  echo "请运行: dcc probe   # 重新探测可用源"
                  exit 1
                fi
              else
                # —— 决定目标版本 ——
                CUR_VER="$(cat VERSION 2>/dev/null || echo "")"
                if [ "$TARGET_VER" = "keep" ]; then
                  NEW_VER="$CUR_VER"
                  echo "  --keep: 保持当前版本 ${CUR_VER:-（无 VERSION 文件）}（仅刷新镜像 layer）" >&2
                elif [ -n "$TARGET_VER" ]; then
                  NEW_VER="$TARGET_VER"
                  echo "  --to=$NEW_VER: 切到指定版本" >&2
                else
                  echo "  探测 latest 版本..." >&2
                  # api.github.com 走直链（ghfast 多数不代理 API）；DCC_API_BASE 允许 bats
                  # 注入 mock / GHE 用户改 API 基址。管道末尾 || true 兜底 set -e + pipefail，
                  # 否则 curl 失败会跳过下方 NEW_VER 检查
                  NEW_VER=$(curl -fsSL --max-time 10 \
                              "${DCC_API_BASE:-https://api.github.com}/repos/${DCC_REPO}/releases/latest" 2>/dev/null \
                              | grep -E '"tag_name"[[:space:]]*:' | head -1 \
                              | sed -E 's/.*"tag_name"[[:space:]]*:[[:space:]]*"v?([^"]+)".*/\1/' \
                              || true)
                  if [ -z "$NEW_VER" ]; then
                    echo "  ✗ 无法探测 latest 版本（api.github.com 不可达或 release 不存在）" >&2
                    echo "    用 dcc upgrade --to=<x.y.z> 指定版本，或 dcc upgrade --keep 保持当前" >&2
                    exit 1
                  fi
                fi

                # —— 更新 VERSION + .env DCC_IMAGE tag（如果版本变化）——
                if [ "$NEW_VER" != "$CUR_VER" ] && [ "$TARGET_VER" != "keep" ]; then
                  echo "  升级 ${CUR_VER:-（无 VERSION 文件）} → $NEW_VER"
                  echo "$NEW_VER" > VERSION
                  if [ -f .env ]; then
                    sed -i.bak -E "s|(/docker-cc:)[^\"[:space:]]+|\\1${NEW_VER}|" .env
                    rm -f .env.bak
                  fi
                elif [ "$NEW_VER" = "$CUR_VER" ] && [ "$TARGET_VER" != "keep" ]; then
                  echo "  当前已是 $NEW_VER，跳过版本切换"
                fi

                # —— pull 镜像（失败回退 VERSION + .env）——
                if ! docker compose pull; then
                  if [ "$NEW_VER" != "$CUR_VER" ] && [ "$TARGET_VER" != "keep" ]; then
                    echo "  pull 失败，回退版本到 ${CUR_VER:-（无）}" >&2
                    echo "$CUR_VER" > VERSION
                    if [ -f .env ]; then
                      sed -i.bak -E "s|(/docker-cc:)[^\"[:space:]]+|\\1${CUR_VER}|" .env
                      rm -f .env.bak
                    fi
                  fi
                  echo ""
                  echo "pull 失败。常见原因："
                  echo "  - registry 不可达（试 dcc upgrade --build 走本地构建）"
                  echo "  - 版本 $NEW_VER 不存在（用 dcc upgrade --to=<可用版本>）"
                  echo "  - DCC_IMAGE 配置错（检查 ~/.docker-cc/repo/.env）"
                  exit 1
                fi

                # —— 真升级时同步宿主脚本（dcc / dcc-use / compose / scripts 等）——
                # 从 release tarball 拉对应版本的 bin/* 等覆盖 $COMPOSE_DIR，避免 image
                # 升级后宿主 dcc/dcc-use 还是旧版（如缺 dcc-use registry 等新命令）。
                # --keep / --build / NEW_VER==CUR_VER 跳过（无变化无需拉）。
                if [ "$TARGET_VER" != "keep" ] && [ "$NEW_VER" != "$CUR_VER" ]; then
                  echo "  同步宿主脚本（dcc / dcc-use / compose）..." >&2
                  GHPROXY="${DCC_GHPROXY-https://ghfast.top/}"
                  TARBALL_URL="${GHPROXY}https://github.com/${DCC_REPO}/releases/download/v${NEW_VER}/docker-cc-${NEW_VER}.tgz"
                  TMP_UPGRADE=$(mktemp -d)
                  if curl -fsSL --max-time 60 "$TARBALL_URL" -o "$TMP_UPGRADE/r.tgz" 2>/dev/null \
                     && tar xz -C "$TMP_UPGRADE" -f "$TMP_UPGRADE/r.tgz" --strip-components=1 2>/dev/null; then
                    # 保护用户数据：不动 .env / providers / VERSION（VERSION 已由本函数改过）
                    # 覆盖：bin/* / scripts/* / docker-compose.yml / Dockerfile / entrypoint.sh / .env.example
                    cp "$TMP_UPGRADE/bin/"* "$COMPOSE_DIR/bin/" 2>/dev/null || true
                    chmod +x "$COMPOSE_DIR/bin/"* 2>/dev/null || true
                    for f in docker-compose.yml Dockerfile entrypoint.sh .env.example; do
                      [ -f "$TMP_UPGRADE/$f" ] && cp "$TMP_UPGRADE/$f" "$COMPOSE_DIR/"
                    done
                    if [ -d "$TMP_UPGRADE/scripts" ]; then
                      mkdir -p "$COMPOSE_DIR/scripts"
                      cp "$TMP_UPGRADE/scripts/"* "$COMPOSE_DIR/scripts/" 2>/dev/null || true
                    fi
                    echo "  ✓ 宿主 dcc / dcc-use / compose 已同步到 $NEW_VER" >&2
                  else
                    echo "  ⚠ 同步 tarball 失败（${TARBALL_URL}）" >&2
                    echo "    镜像已升到 $NEW_VER，但宿主 dcc/dcc-use 未更新" >&2
                    echo "    手动同步: curl -fsSL https://ghfast.top/raw.githubusercontent.com/${DCC_REPO}/main/scripts/quick-install.sh | DCC_VERSION=${NEW_VER} bash -s -- --skip-link" >&2
                  fi
                  rm -rf "$TMP_UPGRADE"
                fi
              fi
              docker compose up -d --force-recreate mihomo
              docker compose run --rm cc claude --version
              echo "升级完成。配置和凭据未受影响（都在卷挂载目录）。" ;;
            mihomo)
              echo "升级 mihomo 内核：修改 Dockerfile 的 ARG MIHOMO_VERSION，然后 dcc upgrade claude --build" ;;
            *)
              echo "用法: dcc upgrade [--build|--keep|--to=<version>] [claude|mihomo|all]"; exit 1 ;;
          esac ;;
  update)
          echo "提示：dcc update 不会持久化（容器层 npm 更新会被丢弃）。"
          echo "请使用 dcc upgrade（rebuild 镜像）。"
          exit 1 ;;
  *)
    # 默认：透传给 claude
    # docker compose up -d 是幂等操作：已运行则 no-op，未运行则启动
    docker compose up -d mihomo >/dev/null
    exec docker compose run --rm cc claude "$@"
    ;;
esac
