#!/usr/bin/env bash
# dcc-use：LLM 供应商管理 + 切换。同一份脚本同时部署在宿主和容器内。
# 详见 docs/implementation-plan.md §7.2

set -eo pipefail

# 容器/宿主自动适配路径
if [ -f /.dockerenv ]; then
  PROVIDERS_DIR="${PROVIDERS_DIR:-/root/.cc-providers}"
  SETTINGS="${CLAUDE_SETTINGS:-/root/.claude/settings.json}"
else
  PROVIDERS_DIR="${PROVIDERS_DIR:-$HOME/.docker-cc/providers}"
  SETTINGS="${CLAUDE_SETTINGS:-$HOME/.docker-cc/claude/settings.json}"
fi
mkdir -p "$PROVIDERS_DIR" "$(dirname "$SETTINGS")" 2>/dev/null || true
[ -f "$SETTINGS" ] || echo '{}' > "$SETTINGS"

# —— 工具函数 ——

# 脱敏 API Key：sk-ant-xxxxxxxx → sk-ant-***xxxx
mask_key() {
  local v="$1"
  [ -z "$v" ] && return
  if [ ${#v} -le 8 ]; then echo "***"; else
    echo "${v:0:7}***${v: -4}"
  fi
}

# 当前激活的供应商：用 settings.json 的 env.ANTHROPIC_BASE_URL 反查 providers/*.json
current_provider() {
  local cur_url cur_token
  cur_url=$(jq -r '.env.ANTHROPIC_BASE_URL // empty' "$SETTINGS" 2>/dev/null)
  cur_token=$(jq -r '.env.ANTHROPIC_AUTH_TOKEN // .env.ANTHROPIC_API_KEY // empty' "$SETTINGS" 2>/dev/null)

  if [ -z "$cur_token" ] && [ -z "$cur_url" ]; then
    # env 空 → OAuth 模式，找 _mode=oauth 的供应商
    for f in "$PROVIDERS_DIR"/*.json; do
      [ -f "$f" ] || continue
      if [ "$(jq -r '._mode // empty' "$f" 2>/dev/null)" = "oauth" ]; then
        basename "$f" .json
        return
      fi
    done
    return
  fi

  for f in "$PROVIDERS_DIR"/*.json; do
    [ -f "$f" ] || continue
    if [ "$(jq -r '.ANTHROPIC_BASE_URL // empty' "$f" 2>/dev/null)" = "$cur_url" ]; then
      basename "$f" .json
      return
    fi
  done
}

# —— 子命令实现 ——

cmd_list() {
  local active
  active=$(current_provider)
  printf "%-2s %-18s %-45s %s\n" "" "NAME" "BASE_URL" "TYPE"
  for f in "$PROVIDERS_DIR"/*.json; do
    [ -f "$f" ] || continue
    local name url mode marker
    name=$(basename "$f" .json)
    url=$(jq -r '.ANTHROPIC_BASE_URL // "-"' "$f" 2>/dev/null)
    mode=$(jq -r '._mode // "api-key"' "$f" 2>/dev/null)
    [ "$name" = "$active" ] && marker="★" || marker=" "
    printf "%-2s %-18s %-45s %s\n" "$marker" "$name" "$url" "$mode"
  done
}

cmd_current() {
  local n
  n=$(current_provider)
  [ -n "$n" ] && echo "$n" || echo "(none)"
}

cmd_show() {
  local name="$1" file
  [ -z "$name" ] && { echo "用法: dcc-use show <name>"; exit 1; }
  file="$PROVIDERS_DIR/${name}.json"
  [ -f "$file" ] || { echo "找不到供应商: $name"; exit 1; }
  # token 字段脱敏
  jq 'with_entries(
        if (.key | endswith("TOKEN")) or (.key | endswith("API_KEY"))
        then .value = (if .value | length > 8
                       then (.value[0:7] + "***" + .value[-4:])
                       else "***" end)
        else . end
      )' "$file"
}

cmd_add() {
  local name="$1"; shift || true
  [ -z "$name" ] && { echo "用法: dcc-use add <name> [--mode=oauth | --api-key=K --base-url=U ...]"; exit 1; }

  local mode="api-key" api_key="" base_url="" model="" small_model="" key_name="ANTHROPIC_AUTH_TOKEN"
  while [ $# -gt 0 ]; do
    case "$1" in
      --mode=*)        mode="${1#--mode=}" ;;
      --api-key=*)     api_key="${1#--api-key=}" ;;
      --base-url=*)    base_url="${1#--base-url=}" ;;
      --model=*)       model="${1#--model=}" ;;
      --small-model=*) small_model="${1#--small-model=}" ;;
      --key-name=*)    key_name="${1#--key-name=}" ;;
      *) echo "未知参数: $1"; exit 1 ;;
    esac
    shift
  done

  local file="$PROVIDERS_DIR/${name}.json"
  [ -f "$file" ] && { echo "供应商已存在: ${name}（用 dcc-use edit ${name} 修改，或先 dcc-use remove ${name}）"; exit 1; }

  if [ "$mode" = "oauth" ]; then
    jq -n '{ _mode: "oauth", _comment: "OAuth 模式：切到此供应商后运行 dcc login" }' \
      > "$file"
    chmod 600 "$file"   # 含敏感配置（即使 OAuth 模板无 token，保持权限一致）
    echo "已创建 OAuth 供应商: ${name}（运行 dcc-use ${name} && dcc login 完成登录）"
    return
  fi

  # 缺参数交互式补齐；非交互环境（bats / CI / piped stdin）下 read 立即 EOF，
  # 加 || true 容忍，让变量保持空值后续 jq 处理
  if [ -z "$api_key" ];     then read -rsp "API Key: " api_key                                 || true; echo; fi
  if [ -z "$base_url" ];    then read -rp  "Base URL: " base_url                               || true; fi
  if [ -z "$model" ];       then read -rp  "Model (可选，主对话): " model                       || true; fi
  if [ -z "$small_model" ]; then read -rp  "Small/Fast Model (可选，后台小任务): " small_model || true; fi

  jq -n --arg k "$key_name" --arg t "$api_key" --arg u "$base_url" \
        --arg m "$model"   --arg sm "$small_model" \
    '{ ($k): $t, ANTHROPIC_BASE_URL: $u } +
     (if $m  == "" then {} else {ANTHROPIC_MODEL: $m} end) +
     (if $sm == "" then {} else {ANTHROPIC_SMALL_FAST_MODEL: $sm} end)' \
    > "$file"
  chmod 600 "$file"     # 含明文 API key，仅当前用户可读
  echo "已添加供应商: ${name} → $file"
}

cmd_edit() {
  local name="$1" file
  [ -z "$name" ] && { echo "用法: dcc-use edit <name>"; exit 1; }
  file="$PROVIDERS_DIR/${name}.json"
  [ -f "$file" ] || { echo "找不到: $name"; exit 1; }
  [ -w "$file" ] || { echo "providers 目录在容器内只读，请在宿主调用 dcc-use edit"; exit 1; }
  exec "${EDITOR:-vi}" "$file"
}

cmd_remove() {
  local name="$1" file
  [ -z "$name" ] && { echo "用法: dcc-use remove <name>"; exit 1; }
  file="$PROVIDERS_DIR/${name}.json"
  [ -f "$file" ] || { echo "找不到: $name"; exit 1; }
  read -rp "确认删除供应商 $name? [y/N] " ans
  if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
    rm -f "$file"
    echo "已删除: $name"
  else
    echo "取消"
  fi
}

cmd_test() {
  local name="${1:-$(current_provider)}"
  [ -z "$name" ] && { echo "无激活供应商，且未指定 name"; exit 1; }
  local file="$PROVIDERS_DIR/${name}.json"
  [ -f "$file" ] || { echo "找不到: ${name}"; exit 1; }

  local mode url token
  mode=$(jq -r '._mode // "api-key"' "$file")
  if [ "$mode" = "oauth" ]; then
    echo "${name}: OAuth 模式（无 base_url 可测，靠 ~/.claude/.credentials.json）"
    return 0
  fi
  url=$(jq -r '.ANTHROPIC_BASE_URL // empty' "$file")
  token=$(jq -r '.ANTHROPIC_AUTH_TOKEN // .ANTHROPIC_API_KEY // empty' "$file")
  [ -n "$url" ] || { echo "${name}: 无 ANTHROPIC_BASE_URL"; exit 1; }

  # 探测 /v1/messages（Anthropic API 核心接口，所有兼容供应商都实现）
  # 用最小 POST + 占位 model：max_tokens=1 + 1 字符 content，正常情况下 model 错会返回 400
  # 同时带 x-api-key（Anthropic 标准）和 Bearer（部分供应商也接受），增加适配性
  local code
  code=$(curl -s -o /dev/null -w '%{http_code}' -m 5 \
           -X POST "$url/v1/messages" \
           -H "x-api-key: $token" \
           -H "Authorization: Bearer $token" \
           -H "anthropic-version: 2023-06-01" \
           -H "Content-Type: application/json" \
           -d '{"model":"__cc_probe__","max_tokens":1,"messages":[{"role":"user","content":"."}]}' \
           2>/dev/null || echo "000")

  printf "%s → %s: HTTP %s  " "${name}" "$url" "$code"
  case "$code" in
    200|201)
      echo "意外的 200（探测 model 名应该不存在）—— endpoint 工作但行为异常" ;;
    400|404)
      # 400 = body/model 校验错；404 在 /v1/messages 上多半是 unknown model（具体看 provider）
      echo "✓ endpoint 通 + token 有效（占位 model 被拒是预期）" ;;
    401|403)
      echo "✗ token 无效或权限错（base_url 可能 OK）" ;;
    405)
      echo "✗ POST 不被允许（base_url 路径可能错）" ;;
    422)
      echo "✓ endpoint 通（请求格式被校验）" ;;
    5*)
      echo "✗ 服务端故障（${code}），稍后重试" ;;
    000)
      echo "✗ 网络不通（mihomo 代理 / DNS / 节点 任一可能）" ;;
    *)
      echo "（未知状态）" ;;
  esac
}

cmd_switch() {
  local name="$1" file
  [ -z "$name" ] && { echo "用法: dcc-use <name>"; cmd_list; exit 1; }
  file="$PROVIDERS_DIR/${name}.json"
  [ -f "$file" ] || { echo "找不到供应商: $name"; cmd_list; exit 1; }

  if [ "$(jq -r '._mode // empty' "$file")" = "oauth" ]; then
    jq '.env = {}' "$SETTINGS" > "$SETTINGS.tmp" && mv "$SETTINGS.tmp" "$SETTINGS"
    echo "已切换到 OAuth 模式: ${name}（如未登录请运行 dcc login）"
  else
    jq --slurpfile p "$file" \
       '.env = ($p[0] | with_entries(select(.key | startswith("_") | not)))' \
       "$SETTINGS" > "$SETTINGS.tmp" && mv "$SETTINGS.tmp" "$SETTINGS"
    echo "已切换到 API Key 供应商: $name"
  fi
}

cmd_registry() {
  # 切换 docker image registry（改宿主 ~/.docker-cc/repo/.env 的 DCC_IMAGE 前缀）
  # 注：容器内默认 DOCKER_CC_HOME 不存在，下方 [ -f $repo_env ] 检查兜底
  local repo_env="${DOCKER_CC_HOME:-$HOME/.docker-cc}/repo/.env"
  if [ ! -f "$repo_env" ]; then
    echo "未找到 $repo_env（先跑 install.sh，或容器内运行需指定 DOCKER_CC_HOME）" >&2
    exit 1
  fi

  # 硬编默认（与 install.sh 一致）；fork 用户可用 DCC_ALIYUN_PREFIX / DCC_GHCR_OWNER 覆盖
  local ALIYUN_PREFIX="${DCC_ALIYUN_PREFIX:-crpi-rskelsy8ldqvpz46.cn-shanghai.personal.cr.aliyuncs.com/stephenluo}"
  local GHCR_OWNER="${DCC_GHCR_OWNER:-stephenluo}"
  local GHCR_PREFIX="ghcr.io/$GHCR_OWNER"

  # 解析当前 DCC_IMAGE；管道末尾 || true 兜底 set -e + pipefail（grep 找不到时
  # 整个 cur_img=$(...) 会失败导致脚本静默退出，看不到下方 fail 提示）
  local cur_img cur_tag cur_prefix cur_label
  cur_img=$(grep '^DCC_IMAGE=' "$repo_env" 2>/dev/null | head -1 | sed 's/^DCC_IMAGE=//; s/^"//; s/"$//' || true)
  if [ -z "$cur_img" ]; then
    echo "$repo_env 里没找到 DCC_IMAGE 行" >&2
    exit 1
  fi
  cur_tag="${cur_img##*:}"
  cur_prefix="${cur_img%/docker-cc:*}"
  case "$cur_prefix" in
    "$ALIYUN_PREFIX") cur_label="cn (阿里云 ACR)" ;;
    "$GHCR_PREFIX")   cur_label="global (GHCR)" ;;
    *)                cur_label="自定义 ($cur_prefix)" ;;
  esac

  local action="${1:-show}"
  local new_prefix=""
  case "$action" in
    show)
      echo "当前 registry: $cur_label"
      echo "  prefix: $cur_prefix"
      echo "  image:  $cur_img"
      echo
      echo "切换："
      echo "  dcc-use registry cn               → 阿里云 ACR"
      echo "  dcc-use registry global           → GHCR"
      echo "  dcc-use registry <自定义前缀>     → 任意 registry/owner"
      return ;;
    cn)     new_prefix="$ALIYUN_PREFIX" ;;
    global) new_prefix="$GHCR_PREFIX" ;;
    -h|--help)
      echo "用法: dcc-use registry [show|cn|global|<自定义前缀>]"
      return ;;
    *)      new_prefix="$action" ;;
  esac

  if [ "$new_prefix" = "$cur_prefix" ]; then
    echo "当前已是 $cur_label，无需切换"
    return
  fi

  # 改 .env 的 DCC_IMAGE
  local new_img="${new_prefix}/docker-cc:${cur_tag}"
  sed -i.bak "s|^DCC_IMAGE=.*|DCC_IMAGE=${new_img}|" "$repo_env"
  rm -f "${repo_env}.bak"
  echo "  ✓ 已切到 $new_img"
  echo "  运行 'dcc upgrade --keep' 从新 registry 拉镜像"
}

cmd_help() {
  cat <<'EOF'
用法: dcc-use [子命令] [参数]

查看：
  dcc-use                              列出所有供应商，★ 标记当前激活
  dcc-use list                         同上
  dcc-use current                      仅打印当前激活的供应商名
  dcc-use show <name>                  显示某供应商详情（API Key 脱敏）

增删改：
  dcc-use add <name> --api-key=KEY --base-url=URL [--model=NAME] [--small-model=NAME] [--key-name=VAR]
  dcc-use add <name> --mode=oauth      创建 OAuth 模式供应商
  dcc-use add <name>                   缺参数则交互式补齐
  dcc-use edit <name>                  用 $EDITOR 编辑供应商 JSON
  dcc-use remove <name>                删除（带确认）

切换：
  dcc-use <name>                       切到该供应商（OAuth 模式自动清空 env）

镜像源（registry）：
  dcc-use registry                     显示当前 registry
  dcc-use registry cn                  切到阿里云 ACR
  dcc-use registry global              切到 GHCR
  dcc-use registry <前缀>              切到自定义 registry prefix

调试：
  dcc-use test [<name>]                curl 探测 base_url 是否可达
EOF
}

# —— 主入口 ——
case "${1:-list}" in
  ""|list)    cmd_list ;;
  current)    cmd_current ;;
  show)       shift; cmd_show "$@" ;;
  add)        shift; cmd_add "$@" ;;
  edit)       shift; cmd_edit "$@" ;;
  remove|rm)  shift; cmd_remove "$@" ;;
  test)       shift; cmd_test "$@" ;;
  registry)   shift; cmd_registry "$@" ;;
  -h|--help|help) cmd_help ;;
  *)          cmd_switch "$1" ;;
esac
