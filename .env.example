# 必填：Clash/Mihomo 订阅 URL（机场提供）
# 必须返回 Clash/Mihomo 兼容的 yaml；V2Ray 等格式需用 subconverter 转一下
CLASH_SUB_URL=

# 可选：metacubexd 面板宿主端口（默认 19090，避开 Clash Verge 的 9090）
# UI_PORT=19090

# 可选：cc 启动时自动切到指定 LLM 供应商
# DCC_PROVIDER=anthropic

# —— 国内构建加速（默认开启，由 docker-compose.yml 的 build.args 读取）——
# 出国/海外用户可清空对应值关闭加速：
# APT_MIRROR=
# GH_PROXY=
# NPM_REGISTRY=
